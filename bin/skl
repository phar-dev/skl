#!/usr/bin/env node
/**
 * skl CLI - Wrapper que ejecuta el CLI real
 */
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';
import { existsSync } from 'fs';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Para desarrollo local: busca ../dist desde bin/
// Para producción: busca dist/ relativo al paquete
let distPath = join(__dirname, '..', 'dist', 'index.js');

if (!existsSync(distPath)) {
  // En producción, el paquete está en node_modules
  const { createRequire } = await import('module');
  const require = createRequire(import.meta.url);
  const pkgPath = dirname(require.resolve('@phardev/skl/package.json'));
  distPath = join(pkgPath, 'dist', 'index.js');
}

await import(distPath);
